      "units": "mph",
      "description": "Daily average wind speed, clipped at 0."
    },
    "log_wind_speed": {
      "units": "log(mph+1)",
      "description": "log1p(avg_wind_speed). Compresses wind distribution."
    },
    "temp_range": {
      "units": "degrees F",
      "description": "(max_temp - min_temp), clipped at 0. Proxy for diurnal swing / clear-sky conditions."
    },
    "precip_lag_7": {
      "units": "log(mm+1)",
      "description": "Precipitation 7 days prior (per-hex shift). Captures short-memory wetness."
    },
    "precip_lag_14": {
      "units": "log(mm+1)",
      "description": "Precipitation 14 days prior (per-hex shift)."
    },
    "precip_rolling_7": {
      "units": "log(mm+1)",
      "description": "7-day rolling mean of precipitation. Low = recent dry spell."
    },
    "precip_rolling_30": {
      "units": "log(mm+1)",
      "description": "30-day rolling mean of precipitation. Medium-term wetness."
    },
    "max_temp_rolling_7": {
      "units": "degrees F",
      "description": "7-day rolling mean of max_temp."
    },
    "wind_rolling_7": {
      "units": "mph",
      "description": "7-day rolling mean of avg_wind_speed."
    },
    "drought_index": {
      "units": "cumulative deficit",
      "description": "30-day rolling sum of (precip_median - precipitation).clip(0). Higher = sustained precipitation deficit."
    },
    "vpd": {
      "units": "kPa",
      "description": "Vapor Pressure Deficit from max/min temp via Tetens formula. Higher = drier air = greater fire risk."
    },
    "vpd_rolling_7": {
      "units": "kPa",
      "description": "7-day rolling mean of VPD."
    },
    "vpd_rolling_30": {
      "units": "kPa",
      "description": "30-day rolling mean of VPD."
    },
