      "units": "meters",
      "description": "Mean surface elevation of the hex."
    },
    "log_elevation": {
      "units": "log(meters)",
      "description": "log1p(elevation). Compresses elevation distribution."
    },
    "precipitation": {
      "units": "log(mm+1)",
      "description": "Daily precipitation, log1p-transformed in place. Lower = drier day."
    },
    "max_temp": {
      "units": "degrees F",
      "description": "Daily maximum temperature at the hex."
    },
    "min_temp": {
      "units": "degrees F",
      "description": "Daily minimum temperature. Values < -20 F treated as NaN (API error)."
    },
